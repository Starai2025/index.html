<script>
  // ---- Replace with your live Typeform link when ready ----
  const INTAKE_URL = "https://form.jotform.com/261673578323060";
  document.querySelectorAll('.js-intake').forEach(function(el){
    if (INTAKE_URL !== "#") el.setAttribute('href', INTAKE_URL);
  });

  // ---- Mobile nav ----
  const hamburgerBtn = document.getElementById('hamburgerBtn');
  const mobilePanel = document.getElementById('mobilePanel');
  hamburgerBtn.addEventListener('click', function(){
    const open = mobilePanel.classList.toggle('open');
    hamburgerBtn.setAttribute('aria-expanded', open ? 'true' : 'false');
  });
  mobilePanel.querySelectorAll('a').forEach(function(a){
    a.addEventListener('click', function(){ mobilePanel.classList.remove('open'); });
  });

  // ---- FAQ accordion ----
  document.querySelectorAll('.faq-item').forEach(function(item){
    const btn = item.querySelector('.faq-q');
    const ans = item.querySelector('.faq-a');
    btn.addEventListener('click', function(){
      const isOpen = item.classList.contains('open');
      document.querySelectorAll('.faq-item.open').forEach(function(openItem){
        if (openItem !== item){
          openItem.classList.remove('open');
          openItem.querySelector('.faq-a').style.maxHeight = null;
        }
      });
      item.classList.toggle('open', !isOpen);
      ans.style.maxHeight = !isOpen ? ans.scrollHeight + 'px' : null;
    });
  });

  // ---- Redline signature typewriter ----
  const newLine = "Directed daily operations for a 24-person team, cutting scheduling conflicts 38% through a redesigned shift system.";
  const typedEl = document.getElementById('typedText');
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function typeRedline(){
    if (!typedEl) return;
    if (reduceMotion){ typedEl.textContent = newLine; return; }
    let i = 0;
    typedEl.textContent = '';
    (function step(){
      if (i <= newLine.length){
        typedEl.textContent = newLine.slice(0, i);
        i++;
        setTimeout(step, 16);
      }
    })();
  }

  const redlineCard = document.getElementById('redlineCard');
  if ('IntersectionObserver' in window && redlineCard){
    const io = new IntersectionObserver(function(entries){
      entries.forEach(function(entry){
        if (entry.isIntersecting){ typeRedline(); io.disconnect(); }
      });
    }, {threshold:0.4});
    io.observe(redlineCard);
  } else {
    typeRedline();
  }

  // ---- Scroll reveal ----
  const revealEls = document.querySelectorAll('.reveal');
  if ('IntersectionObserver' in window){
    const revealIO = new IntersectionObserver(function(entries){
      entries.forEach(function(entry){
        if (entry.isIntersecting){
          entry.target.classList.add('is-visible');
          revealIO.unobserve(entry.target);
        }
      });
    }, {threshold:0.12});
    revealEls.forEach(function(el){ revealIO.observe(el); });
  } else {
    revealEls.forEach(function(el){ el.classList.add('is-visible'); });
  }
</script>

</body>
</html>
